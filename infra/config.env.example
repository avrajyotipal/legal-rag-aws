# ─── Admin credentials (used by setup scripts only) ─────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_admin_access_key_here
AWS_SECRET_ACCESS_KEY=your_admin_secret_key_here

# ─── Resource names (auto-managed by setup scripts) ──────────────────────────
S3_BUCKET_NAME=legal-rag-documents
OPENSEARCH_DOMAIN_NAME=legal-rag-domain
OPENSEARCH_INDEX=legal-docs

# ─── Service account credentials (auto-populated by setup_iam.sh) ────────────
SVC_ACCESS_KEY_ID=
SVC_SECRET_ACCESS_KEY=

# ─── OpenSearch endpoint (auto-populated by setup_opensearch.sh) ─────────────
OPENSEARCH_ENDPOINT=

# ─── Bedrock model IDs ───────────────────────────────────────────────────────
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_DIMENSIONS=1024
BEDROCK_LLM_MODEL_ID=amazon.nova-pro-v1:0

# ─── Chunking parameters ─────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─── Retrieval parameters ────────────────────────────────────────────────────
TOP_K=5
RERANK_ALPHA=0.7
PRE_RERANK_K=10
